# --- Neo4j -----------------------------------------------------------------
NEO4J_URI=neo4j+s://<id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# --- Azure OpenAI ----------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=

# --- GitHub (knowledge graph — README ingestion) ---------------------------
# Personal Access Token with `public_repo` scope (5000 req/h authenticated).
# Generate at: https://github.com/settings/tokens
# Without a token the API allows only 60 unauthenticated requests per hour
# and private repos are invisible.
GITHUB_TOKEN=
