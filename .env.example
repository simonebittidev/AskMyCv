# --- Neo4j Aura ---------------------------------------------------------
NEO4J_URI=neo4j+s://<id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# --- Azure OpenAI -------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
# Deployment names (must match the names you created in your Azure resource)
AZURE_OPENAI_LLM_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- GitHub (knowledge graph projects ingestion) ------------------------
# Personal Access Token with public_repo scope (5000 req/h).
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_USERNAME=simonebitti

# --- KG builder overrides (optional) ------------------------------------
# KG_PDF_FOLDER=files/Simone Bitti
# KG_PROJECTS_CONFIG=config/projects.yml
# KG_PERSON_NAME=Simone Bitti
# KG_ENABLE_COMMUNITIES=true
